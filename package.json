{
  "name": "status-bar-task-buttons",
  "displayName": "Status bar task buttons",
  "description": "Add configurable task buttons to the status bar for quick execution of user-defined tasks from VS Code settings",
  "keywords": [
    "tasks",
    "status bar",
    "buttons",
    "quick access",
    "workspace",
    "productivity",
    "toolbar",
    "task runner"
  ],
  "version": "1.0.1",
  "publisher": "GKanev",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GrigoriyKanev/vscode-task-buttons"
  },
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Simple Task Buttons",
      "properties": {
        "taskButtons.buttons": {
          "type": "array",
          "scope": "window",
          "default": [],
          "markdownDescription": "Task buttons shown in the status bar. Configure this in User settings so each user keeps their own buttons and command mappings.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "task"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for the button"
              },
              "task": {
                "type": "string",
                "description": "Name of the task defined in taskButtons.tasks"
              },
              "icon": {
                "type": "string",
                "description": "Icon to display before the button name"
              },
              "tooltip": {
                "type": "string",
                "description": "Tooltip text shown when hovering over the button"
              }
            }
          }
        },
        "taskButtons.tasks": {
          "type": "array",
          "scope": "window",
          "default": [],
          "markdownDescription": "User-defined tasks that buttons can run. Each task is stored in User settings and executed directly from an inline command.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "command"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Task name referenced by taskButtons.buttons"
              },
              "command": {
                "type": "string",
                "description": "Executable to run. Defaults to powershell.exe when omitted."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Optional command arguments"
              },
              "script": {
                "type": "string",
                "description": "Optional inline script passed to the executable with -Command"
              }
            }
          }
        }
      }
    },
    "commands": [
      {
        "command": "taskButtons.refresh",
        "title": "Refresh Task Buttons"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "18.x",
    "typescript": "^4.9.4"
  }
}